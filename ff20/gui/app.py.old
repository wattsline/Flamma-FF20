from __future__ import annotations

import json
import sys
import traceback
from pathlib import Path

from PySide6.QtCore import QObject, QRunnable, Qt, QThreadPool, QTimer, Signal
from PySide6.QtGui import QAction, QKeySequence
from PySide6.QtWidgets import (
    QApplication,
    QCheckBox,
    QComboBox,
    QFileDialog,
    QGroupBox,
    QHBoxLayout,
    QHeaderView,
    QLabel,
    QMainWindow,
    QMessageBox,
    QPushButton,
    QProgressBar,
    QSpinBox,
    QTableWidget,
    QTableWidgetItem,
    QVBoxLayout,
    QWidget,
)

from ff20.exceptions import DeviceNotFoundError, FF20Error
from ff20.pedal import FF20Pedal, LoopInfo


STATUS_STYLES = {
    "none": "color: #7a7a7a; font-weight: 600;",
    "connecting": "color: #b77900; font-weight: 700;",
    "connected": "color: #16803c; font-weight: 700;",
    "error": "color: #b00020; font-weight: 700;",
}


class WorkerSignals(QObject):
    success = Signal(object)
    error = Signal(str, bool)  # message, user_friendly
    progress = Signal(int)
    status = Signal(str)
    finished = Signal(object)


class Worker(QRunnable):
    def __init__(self, fn, *args, **kwargs):
        super().__init__()
        self.fn = fn
        self.args = args
        self.kwargs = kwargs
        self.signals = WorkerSignals()
        self.setAutoDelete(False)

    def run(self):
        try:
            result = self.fn(
                *self.args,
                progress=self.signals.progress.emit,
                status=self.signals.status.emit,
                **self.kwargs,
            )
            self.signals.success.emit(result)
        except FF20Error as e:
            self.signals.error.emit(str(e), True)
        except Exception:
            msg = traceback.format_exc()
            print(msg, file=sys.stderr, flush=True)
            self.signals.error.emit(msg, False)
        finally:
            self.signals.finished.emit(self)


class MainWindow(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("FF20 Tools")
        self.resize(1100, 720)

        self.thread_pool = QThreadPool.globalInstance()
        self._workers: list[Worker] = []
        self.loops: list[LoopInfo] = []

        self.status = QLabel()
        self.status_detail = QLabel("")
        self.selection_label = QLabel("No selection")
        self.progress = QProgressBar()
        self.progress.setRange(0, 100)

        self.slot_count = QSpinBox()
        self.slot_count.setRange(1, 100)
        self.slot_count.setValue(20)
        self.slot_count.setPrefix("Slots: ")

        self.normalize_import = QCheckBox("Normalize imports")
        self.normalize_preset = QComboBox()
        self.normalize_preset.addItems(["conservative", "standard", "hot"])
        self.normalize_preset.setCurrentText("standard")

        self.btn_connect = QPushButton("Refresh Connection")
        self.btn_refresh = QPushButton("Refresh Slots")

        self.btn_export = QPushButton("Export Selected")
        self.btn_import = QPushButton("Import to Selected")
        self.btn_delete = QPushButton("Delete Selected")
        self.btn_backup = QPushButton("Backup Selected")

        self.btn_select_all = QPushButton("Select All")
        self.btn_select_present = QPushButton("Select Present")
        self.btn_clear_selection = QPushButton("Clear")

        self.table = QTableWidget(0, 5)
        self.table.setHorizontalHeaderLabels(["", "Slot", "Size", "Minutes", "Flags"])
        self.table.horizontalHeader().setSectionResizeMode(QHeaderView.Stretch)
        self.table.horizontalHeader().setSectionResizeMode(0, QHeaderView.ResizeToContents)
        self.table.horizontalHeader().setSectionResizeMode(1, QHeaderView.ResizeToContents)
        self.table.setSelectionBehavior(QTableWidget.SelectRows)
        self.table.setSelectionMode(QTableWidget.ExtendedSelection)
        self.table.setAlternatingRowColors(True)

        self._build_layout()
        self._connect_signals()
        self._install_shortcuts()

        self.set_connection_state("none", "⚪ No Pedal Detected", "Connect your FF20 via USB-C, then click Refresh Connection.")
        QTimer.singleShot(250, self.connect_device)

    def _build_layout(self):
        connection_box = QGroupBox("Connection")
        connection_layout = QVBoxLayout()
        connection_layout.addWidget(self.status)
        connection_layout.addWidget(self.status_detail)

        connection_controls = QHBoxLayout()
        connection_controls.addWidget(self.btn_connect)
        connection_controls.addWidget(self.btn_refresh)
        connection_controls.addWidget(self.slot_count)
        connection_controls.addStretch(1)
        connection_layout.addLayout(connection_controls)
        connection_box.setLayout(connection_layout)

        pedal_box = QGroupBox("Pedal Actions")
        pedal_layout = QHBoxLayout()
        for w in [self.btn_export, self.btn_import, self.btn_delete, self.btn_backup]:
            pedal_layout.addWidget(w)
        pedal_layout.addStretch(1)
        pedal_box.setLayout(pedal_layout)

        selection_box = QGroupBox("Selection")
        selection_layout = QHBoxLayout()
        for w in [self.btn_select_all, self.btn_select_present, self.btn_clear_selection]:
            selection_layout.addWidget(w)
        selection_layout.addWidget(self.selection_label)
        selection_layout.addStretch(1)
        selection_box.setLayout(selection_layout)

        import_box = QGroupBox("Import Options")
        import_layout = QHBoxLayout()
        import_layout.addWidget(self.normalize_import)
        import_layout.addWidget(QLabel("Preset:"))
        import_layout.addWidget(self.normalize_preset)
        import_layout.addStretch(1)
        import_box.setLayout(import_layout)

        layout = QVBoxLayout()
        layout.addWidget(connection_box)
        layout.addWidget(pedal_box)
        layout.addWidget(selection_box)
        layout.addWidget(import_box)
        layout.addWidget(self.table)
        layout.addWidget(self.progress)

        central = QWidget()
        central.setLayout(layout)
        self.setCentralWidget(central)

    def _connect_signals(self):
        self.btn_connect.clicked.connect(self.connect_device)
        self.btn_refresh.clicked.connect(self.refresh_slots)
        self.btn_export.clicked.connect(self.export_selected)
        self.btn_import.clicked.connect(self.import_selected)
        self.btn_delete.clicked.connect(self.delete_selected)
        self.btn_backup.clicked.connect(self.backup_selected)
        self.btn_select_all.clicked.connect(self.table.selectAll)
        self.btn_select_present.clicked.connect(self.select_present)
        self.btn_clear_selection.clicked.connect(self.table.clearSelection)
        self.table.itemSelectionChanged.connect(self.update_selection_label)

    def _install_shortcuts(self):
        shortcuts = [
            ("Refresh", QKeySequence.Refresh, self.refresh_slots),
            ("Import", QKeySequence("Ctrl+I"), self.import_selected),
            ("Export", QKeySequence("Ctrl+E"), self.export_selected),
            ("Select All", QKeySequence.SelectAll, self.table.selectAll),
            ("Clear Selection", QKeySequence(Qt.Key_Escape), self.table.clearSelection),
            ("Delete", QKeySequence.Delete, self.delete_selected),
        ]
        for name, shortcut, callback in shortcuts:
            action = QAction(name, self)
            action.setShortcut(shortcut)
            action.triggered.connect(callback)
            self.addAction(action)

    def set_connection_state(self, state: str, text: str, detail: str = ""):
        self.status.setText(text)
        self.status.setStyleSheet(STATUS_STYLES[state])
        self.status_detail.setText(detail)

    def set_busy(self, busy: bool, text: str | None = None):
        controls = [
            self.btn_connect, self.btn_refresh, self.btn_export, self.btn_import,
            self.btn_delete, self.btn_backup, self.btn_select_all,
            self.btn_select_present, self.btn_clear_selection, self.slot_count,
            self.normalize_import, self.normalize_preset,
        ]
        for c in controls:
            c.setEnabled(not busy)
        if text is not None:
            self.status_detail.setText(text)

    def run_worker(self, fn, on_success, *args, **kwargs):
        self.progress.setValue(0)
        worker = Worker(fn, *args, **kwargs)
        self._workers.append(worker)
        worker.signals.progress.connect(self.progress.setValue)
        worker.signals.status.connect(self.status_detail.setText)
        worker.signals.success.connect(lambda result: self._success(on_success, result))
        worker.signals.error.connect(self.show_error)
        worker.signals.finished.connect(self._worker_finished)
        self.thread_pool.start(worker)

    def _worker_finished(self, worker):
        try:
            self._workers.remove(worker)
        except ValueError:
            pass

    def _success(self, on_success, result):
        self.set_busy(False)
        on_success(result)

    def show_error(self, msg: str, user_friendly: bool):
        self.set_busy(False)
        self.set_connection_state("error", "🔴 Error", "Action failed.")
        if user_friendly:
            QMessageBox.information(self, "FF20 Tools", msg)
        else:
            QMessageBox.critical(self, "Unexpected Error", msg)

    def selected_slots(self) -> list[int]:
        return sorted(int(self.table.item(r.row(), 1).text()) for r in self.table.selectionModel().selectedRows())

    def selected_present_slots(self) -> list[int]:
        return [s for s in self.selected_slots() if 0 <= s < len(self.loops) and self.loops[s].present]

    def require_selection(self) -> list[int] | None:
        slots = self.selected_slots()
        if not slots:
            QMessageBox.information(self, "FF20 Tools", "Select one or more slots first.")
            return None
        return slots

    def update_selection_label(self):
        slots = self.selected_slots()
        if not slots:
            self.selection_label.setText("No selection")
            return
        present = [s for s in slots if 0 <= s < len(self.loops) and self.loops[s].present]
        text = ", ".join(str(s) for s in slots[:20])
        if len(slots) > 20:
            text += "..."
        self.selection_label.setText(f"Selected {len(slots)} slot(s): {text} | present={len(present)} empty={len(slots)-len(present)}")

    def select_present(self):
        self.table.clearSelection()
        for row, loop in enumerate(self.loops):
            if loop.present:
                self.table.selectRow(row)
        self.update_selection_label()

    def connect_device(self):
        def work(progress, status):
            status("Connecting to FF20...")
            with FF20Pedal() as pedal:
                return pedal.info()

        self.set_busy(True)
        self.set_connection_state("connecting", "🟡 Connecting...", "Looking for FF20 over USB-C.")
        self.run_worker(work, self.connect_done)

    def connect_done(self, info):
        self.set_connection_state(
            "connected",
            "🟢 Connected",
            f"{info.product} | Serial {info.serial} | App {info.app_version} | Boot {info.boot_version} | HW {info.hw_version}",
        )
        QTimer.singleShot(100, self.refresh_slots)

    def refresh_slots(self):
        count = int(self.slot_count.value())

        def work(progress, status):
            status(f"Reading {count} slots...")
            with FF20Pedal() as pedal:
                return pedal.list_loops(count=count, progress=progress)

        self.set_busy(True, f"Reading {count} slots...")
        self.run_worker(work, self.refresh_done)

    def refresh_done(self, loops):
        self.loops = loops
        self.table.setRowCount(len(loops))
        for row, item in enumerate(loops):
            filled = "●" if item.present else "○"
            slot_label = f"{item.index:02d}"
            size = str(item.data_length) if item.present else ""
            minutes = f"{item.minutes:.2f}" if item.present else ""
            flags = f"status={item.status_flag} export={item.export_flag}" if item.present else "Empty"

            values = [filled, slot_label, size, minutes, flags]
            for col, value in enumerate(values):
                cell = QTableWidgetItem(value)
                cell.setFlags(cell.flags() & ~Qt.ItemIsEditable)
                if col == 0:
                    cell.setTextAlignment(Qt.AlignCenter)
                    cell.setForeground(Qt.darkGreen if item.present else Qt.gray)
                self.table.setItem(row, col, cell)

        self.status_detail.setText(f"{len(loops)} slots loaded.")
        self.progress.setValue(100)
        self.update_selection_label()

    def export_selected(self):
        slots = self.selected_present_slots()
        if not slots:
            QMessageBox.information(self, "Export Selected", "Select one or more present/non-empty slots.")
            return

        if len(slots) == 1:
            path, _ = QFileDialog.getSaveFileName(self, "Export WAV", f"FF20_LOOPFILE_{slots[0]:02d}.wav", "WAV files (*.wav)")
            if not path:
                return

            def work(progress, status):
                status(f"Exporting slot {slots[0]}...")
                with FF20Pedal() as pedal:
                    return pedal.export_wav(slots[0], Path(path), progress=progress)

            self.set_busy(True, f"Exporting slot {slots[0]}...")
            self.run_worker(work, lambda out: QMessageBox.information(self, "Export complete", str(out)))
            return

        folder = QFileDialog.getExistingDirectory(self, "Choose export folder")
        if not folder:
            return
        dest = Path(folder)

        def work(progress, status):
            exported = []
            with FF20Pedal() as pedal:
                for i, slot in enumerate(slots):
                    status(f"Exporting slot {slot} ({i + 1}/{len(slots)})...")
                    out = dest / f"FF20_LOOPFILE_{slot:02d}.wav"
                    pedal.export_wav(slot, out)
                    exported.append(out)
                    progress(int((i + 1) / len(slots) * 100))
            return exported

        self.set_busy(True, f"Exporting {len(slots)} slots...")
        self.run_worker(work, lambda exported: QMessageBox.information(self, "Export complete", f"Exported {len(exported)} files to:\n{dest}"))

    def import_selected(self):
        slots = self.require_selection()
        if not slots:
            return

        paths, _ = QFileDialog.getOpenFileNames(
            self,
            "Import Audio",
            "",
            "Audio files (*.wav *.flac *.mp3 *.m4a *.aac *.ogg *.aiff);;All files (*.*)",
        )
        if not paths:
            return
        if len(paths) != len(slots):
            QMessageBox.warning(self, "Import mismatch", f"Selected {len(slots)} slot(s), but chose {len(paths)} file(s).")
            return

        occupied = [s for s in slots if 0 <= s < len(self.loops) and self.loops[s].present]
        if occupied:
            answer = QMessageBox.question(
                self,
                "Overwrite slots?",
                "The following selected slots already contain loops:\n"
                f"{', '.join(str(s) for s in occupied)}\n\nContinue?",
            )
            if answer != QMessageBox.Yes:
                return

        normalize = self.normalize_import.isChecked()
        preset = self.normalize_preset.currentText()
        path_objs = [Path(p) for p in paths]

        def work(progress, status):
            imported = []
            with FF20Pedal() as pedal:
                for i, (slot, path) in enumerate(zip(slots, path_objs)):
                    status(f"Importing {path.name} to slot {slot} ({i + 1}/{len(slots)})...")
                    pedal.import_audio(
                        slot,
                        path,
                        normalize=normalize,
                        preset=preset,
                        progress=lambda p, base=i: progress(int((base + p / 100) / len(slots) * 100)),
                    )
                    imported.append(slot)
            return imported

        self.set_busy(True, f"Importing {len(slots)} file(s)...")
        self.run_worker(work, lambda imported: (QMessageBox.information(self, "Import complete", f"Imported {len(imported)} file(s)."), self.refresh_slots()))

    def delete_selected(self):
        slots = self.require_selection()
        if not slots:
            return
        answer = QMessageBox.question(
            self,
            "Delete selected loops?",
            f"Delete {len(slots)} selected slot(s)?\n\n{', '.join(str(s) for s in slots[:40])}{'...' if len(slots) > 40 else ''}",
        )
        if answer != QMessageBox.Yes:
            return

        def work(progress, status):
            deleted = []
            with FF20Pedal() as pedal:
                for i, slot in enumerate(slots):
                    status(f"Deleting slot {slot} ({i + 1}/{len(slots)})...")
                    pedal.delete_loop(slot)
                    deleted.append(slot)
                    progress(int((i + 1) / len(slots) * 100))
            return deleted

        self.set_busy(True, f"Deleting {len(slots)} slot(s)...")
        self.run_worker(work, lambda deleted: (QMessageBox.information(self, "Delete complete", f"Deleted {len(deleted)} slot(s)."), self.refresh_slots()))

    def backup_selected(self):
        slots = self.selected_present_slots()
        if not slots:
            QMessageBox.information(self, "Backup Selected", "Select one or more present/non-empty slots.")
            return
        folder = QFileDialog.getExistingDirectory(self, "Choose backup folder")
        if not folder:
            return
        dest = Path(folder)

        def work(progress, status):
            exported = []
            with FF20Pedal() as pedal:
                info = pedal.info()
                manifest = {"device": info.__dict__, "loops": []}
                for i, slot in enumerate(slots):
                    status(f"Backing up slot {slot} ({i + 1}/{len(slots)})...")
                    out = dest / f"slot{slot:02d}.wav"
                    pedal.export_wav(slot, out)
                    exported.append(out)
                    loop = self.loops[slot] if 0 <= slot < len(self.loops) else None
                    manifest["loops"].append({"slot": slot, "file": out.name, "bytes": loop.data_length if loop else None})
                    progress(int((i + 1) / len(slots) * 100))
            (dest / "manifest.json").write_text(json.dumps(manifest, indent=2))
            return exported

        self.set_busy(True, f"Backing up {len(slots)} slot(s)...")
        self.run_worker(work, lambda exported: QMessageBox.information(self, "Backup complete", f"Backed up {len(exported)} file(s) to:\n{dest}"))


def main() -> None:
    app = QApplication(sys.argv)
    window = MainWindow()
    window.show()
    sys.exit(app.exec())


if __name__ == "__main__":
    main()
